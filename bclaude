#!/bin/zsh
# bclaude — Claude Code workspace launcher
# Install: curl -fsSL https://raw.githubusercontent.com/damienp199/bclaude/main/install.sh | sh

export PATH="$HOME/.local/bin:$PATH"

CONFIG_DIR="$HOME/.config/bclaude"
WORKSPACES_FILE="$CONFIG_DIR/workspaces"

if [[ ! -f "$WORKSPACES_FILE" ]]; then
  mkdir -p "$CONFIG_DIR"
  touch "$WORKSPACES_FILE"
fi

# Le défaut est toujours la ligne 1 du fichier workspaces
DEFAULT_CHOICE=1

# --- Couleurs ---
RST=$'\e[0m'
BOLD=$'\e[1m'
DIM=$'\e[2m'
ORANGE=$'\e[38;5;208m'
WHITE=$'\e[97m'
GRAY=$'\e[38;5;243m'
GREEN=$'\e[38;5;107m'
RED=$'\e[38;5;167m'

# --- Options CLI ---
case "$1" in
  --default)
    if [[ -z "$2" ]]; then
      echo "  Usage: bclaude --default /path/to/project"
      exit 1
    fi
    target="${2%/}"
    if [[ ! -d "$target" ]]; then
      echo "  ✗ Ce dossier n'existe pas : $target"
      exit 1
    fi
    grep -vxF "$target" "$WORKSPACES_FILE" > "$WORKSPACES_FILE.tmp" 2>/dev/null
    { echo "$target"; cat "$WORKSPACES_FILE.tmp"; } > "$WORKSPACES_FILE"
    rm -f "$WORKSPACES_FILE.tmp"
    echo "  ✓ Défaut : $(basename "$target")"
    exit 0
    ;;
  upgrade|--upgrade)
    REPO="https://raw.githubusercontent.com/damienp199/bclaude/main/bclaude"
    INSTALL_PATH="$HOME/.local/bin/bclaude"
    if [[ -L "$INSTALL_PATH" ]]; then
      echo "  ✗ Symlink détecté — utilise git pull dans ton repo local"
      exit 1
    fi
    echo "  Mise à jour..."
    if curl -fsSL "$REPO" -o "$INSTALL_PATH.tmp"; then
      chmod +x "$INSTALL_PATH.tmp"
      mv "$INSTALL_PATH.tmp" "$INSTALL_PATH"
      echo "  ✓ bclaude mis à jour"
    else
      rm -f "$INSTALL_PATH.tmp"
      echo "  ✗ Échec du téléchargement"
      exit 1
    fi
    exit 0
    ;;
  --help|-h)
    echo "  bclaude — Claude Code workspace launcher"
    echo ""
    echo "  Usage:"
    echo "    bclaude              Lancer le menu"
    echo "    bclaude --default P  Définir P comme workspace par défaut"
    echo "    bclaude upgrade      Mettre à jour vers la dernière version"
    echo "    bclaude --help       Afficher cette aide"
    exit 0
    ;;
esac

if ! command -v claude &>/dev/null; then
  echo "  ✗ claude introuvable. https://docs.anthropic.com/en/docs/claude-code"
  exit 1
fi

# --- Restaurer le terminal proprement ---
cleanup() { printf '\e[?25h\e[?1049l'; }
trap cleanup EXIT INT TERM

# --- Lecture clavier ---
read_key() {
  local key k1 k2
  read -rsk1 key
  if [[ "$key" == $'\e' ]]; then
    read -rsk1 -t 0.01 k1
    read -rsk1 -t 0.01 k2
    key+="${k1}${k2}"
  fi
  case "$key" in
    $'\e[A'|k) echo up    ;;
    $'\e[B'|j) echo down  ;;
    ''|$'\n')  echo enter  ;;
    q)         echo quit   ;;
    a)         echo add    ;;
    s)         echo del    ;;
    d)         echo def    ;;
  esac
}

# --- Charger les workspaces ---
load_dirs() {
  DIRS=("${(@f)$(grep -v '^$' "$WORKSPACES_FILE")}")
  [[ ${#DIRS[@]} -eq 1 && -z "${DIRS[1]}" ]] && DIRS=()
}

# --- Charger les sous-dossiers d'un dossier parent ---
load_subdirs() {
  local parent="$1"
  local subdirs=()
  for d in "$parent"/*/; do
    [[ -d "$d" ]] || continue
    d="${d%/}"
    subdirs+=("$d")
  done
  echo "${(F)subdirs}"
}

MAX_RECENTS=5

# --- Convertir un nom de dossier Claude en path réel ---
# Claude encode les paths : / → -, espace → -, etc.
# Ex: -Users-damienpugin-Documents-Apps-Auto-Accounting → /Users/damienpugin/Documents/Apps/Auto Accounting
resolve_claude_path() {
  local encoded="$1"
  encoded="${encoded#-}"  # retirer le tiret initial
  local parts=("${(@s/-/)encoded}")  # split sur -
  local path=""
  local i=1
  while (( i <= ${#parts[@]} )); do
    local candidate="$path/${parts[$i]}"
    if [[ -d "$candidate" ]]; then
      path="$candidate"
      (( i++ ))
    else
      # Essayer de joindre avec les segments suivants (tiret ou espace dans le nom)
      local found=false
      local j=$(( i + 1 ))
      while (( j <= ${#parts[@]} )); do
        # Construire les variantes avec tiret et espace
        local merged_dash="${parts[$i]}"
        local merged_space="${parts[$i]}"
        local k=$(( i + 1 ))
        while (( k <= j )); do
          merged_dash="$merged_dash-${parts[$k]}"
          merged_space="$merged_space ${parts[$k]}"
          (( k++ ))
        done
        if [[ -d "$path/$merged_dash" ]]; then
          path="$path/$merged_dash"
          i=$(( j + 1 ))
          found=true
          break
        elif [[ -d "$path/$merged_space" ]]; then
          path="$path/$merged_space"
          i=$(( j + 1 ))
          found=true
          break
        fi
        (( j++ ))
      done
      if ! $found; then
        echo ""
        return
      fi
    fi
  done
  echo "$path"
}

# --- Charger les récents depuis ~/.claude/projects/ ---
load_recents() {
  RECENTS=()
  local claude_projects="$HOME/.claude/projects"
  [[ ! -d "$claude_projects" ]] && return

  # Lister par date de modification décroissante
  local entries=("${(@f)$(ls -t "$claude_projects" 2>/dev/null)}")

  for entry in "${entries[@]}"; do
    [[ -z "$entry" ]] && continue
    local real_path=$(resolve_claude_path "$entry")
    [[ -z "$real_path" || ! -d "$real_path" ]] && continue
    # Ignorer le home directory (pas un vrai workspace)
    [[ "$real_path" == "$HOME" ]] && continue
    # Exclure ceux déjà dans les workspaces (directs et group-items)
    local already=false
    for d in "${DIRS[@]}"; do
      # Direct workspace
      [[ "$d" == "$real_path" ]] && { already=true; break; }
      # Parent group : vérifier si real_path est un sous-dossier
      if [[ "$d" == ">"* ]]; then
        local parent="${d#>}"
        [[ "$real_path" == "$parent"/* ]] && { already=true; break; }
      fi
    done
    $already && continue
    RECENTS+=("$real_path")
    (( ${#RECENTS[@]} >= MAX_RECENTS )) && break
  done
}

# --- Construire la liste complète (workspaces + récents) ---
build_items() {
  load_dirs
  load_recents
  ITEMS=()
  ITEMS_TYPE=()
  ITEMS_FULL_PATH=()
  ITEMS_GROUP=()  # nom du groupe parent (vide pour les directs)
  for d in "${DIRS[@]}"; do
    if [[ "$d" == ">"* ]]; then
      # Dossier parent : lister ses sous-dossiers
      local parent="${d#>}"
      [[ ! -d "$parent" ]] && continue
      local subdirs=("${(@f)$(load_subdirs "$parent")}")
      [[ ${#subdirs[@]} -eq 0 ]] && continue
      [[ ${#subdirs[@]} -eq 1 && -z "${subdirs[1]}" ]] && continue
      # Header du groupe (non sélectionnable)
      ITEMS+=("$(basename "$parent")")
      ITEMS_TYPE+=(group-header)
      ITEMS_FULL_PATH+=("$parent")
      ITEMS_GROUP+=("")
      # Sous-dossiers (exclure ceux déjà épinglés en direct)
      for sd in "${subdirs[@]}"; do
        [[ -z "$sd" ]] && continue
        local is_direct=false
        for dd in "${DIRS[@]}"; do
          [[ "$dd" == "$sd" ]] && { is_direct=true; break; }
        done
        $is_direct && continue
        ITEMS+=("$(basename "$sd")")
        ITEMS_TYPE+=(group-item)
        ITEMS_FULL_PATH+=("$sd")
        ITEMS_GROUP+=("$parent")
      done
    else
      ITEMS+=("$(basename "$d")")
      ITEMS_TYPE+=(workspace)
      ITEMS_FULL_PATH+=("$d")
      ITEMS_GROUP+=("")
    fi
  done
  RECENT_START_INDEX=$(( ${#ITEMS[@]} + 1 ))
  for d in "${RECENTS[@]}"; do
    ITEMS+=("$(basename "$d")")
    ITEMS_TYPE+=(recent)
    ITEMS_FULL_PATH+=("$d")
    ITEMS_GROUP+=("")
  done
}

# --- S'assurer que selected est sur un item sélectionnable ---
fix_selected() {
  (( selected < 1 )) && selected=1
  (( selected > ${#ITEMS[@]} )) && selected=${#ITEMS[@]}
  while (( selected <= ${#ITEMS[@]} )) && [[ "${ITEMS_TYPE[$selected]}" == "group-header" ]]; do
    (( selected++ ))
  done
  (( selected > ${#ITEMS[@]} )) && selected=${#ITEMS[@]}
}

# --- Dessin du menu ---
draw() {
  clear
  printf '\e[?25l'     # cacher curseur

  local total=${#ITEMS[@]}

  echo ""
  printf "  ${ORANGE}█▀▀ █   █▀█ █ █ █▀▄ █▀▀${RST}   ${BOLD}${WHITE}██▄ █▀█ █▀█ ▀█▀${RST}\n"
  printf "  ${ORANGE}█▄▄ █▄▄ █▀█ █▄█ █▄▀ ██▄${RST}   ${BOLD}${WHITE}██▀ █▄█ █▄█  █ ${RST}\n"
  printf "  ${DIM}workspace launcher${RST}\n"
  echo ""

  # Items
  local shown_workspace_header=false
  local shown_recent_header=false
  for i in {1..$total}; do
    local name="${ITEMS[$i]}"
    local type="${ITEMS_TYPE[$i]}"
    local is_default=false

    # Header de groupe (non sélectionnable)
    if [[ "$type" == "group-header" ]]; then
      printf "\n  ${DIM}── %s ──${RST}\n" "$name"
      continue
    fi

    # Afficher le header "projets" avant le premier workspace
    if [[ "$type" == "workspace" ]] && ! $shown_workspace_header; then
      printf "  ${DIM}── projets ──${RST}\n"
      shown_workspace_header=true
    fi

    # Afficher le header "Récents" avant le premier item recent
    if [[ "$type" == "recent" ]] && ! $shown_recent_header; then
      printf "\n  ${DIM}── récents ──${RST}\n"
      shown_recent_header=true
    fi

    # Le premier workspace est toujours le défaut
    if [[ "$type" == "workspace" && "$i" -eq 1 ]]; then
      is_default=true
    fi

    if (( i == selected )); then
      printf "  ${ORANGE}❯${RST} ${BOLD}${WHITE}%s${RST}" "$name"
    else
      printf "    ${GRAY}%s${RST}" "$name"
    fi

    if $is_default; then
      printf "  ${DIM}${ORANGE}●${RST}"
    fi

    echo ""
  done

  printf "\n  ${DIM}↑↓${RST}${GRAY} naviguer${RST}  ${DIM}⏎${RST}${GRAY} ouvrir${RST}  ${GREEN}a${RST}${GRAY} ajouter${RST}  ${RED}s${RST}${GRAY} supprimer${RST}  ${DIM}d${RST}${GRAY} défaut${RST}  ${DIM}q${RST}${GRAY} quitter${RST}\n"
}

# --- Mode interactif (prompt pour les actions) ---
prompt_input() {
  local label="$1"
  printf '\e[?25h' >&2  # montrer curseur
  printf "\n  ${ORANGE}›${RST} ${label} " >&2
  local value
  read -r value
  printf '\e[?25l' >&2  # cacher curseur
  echo "$value"
}

show_message() {
  local msg="$1"
  printf "\n  ${msg}\n"
  sleep 0.8
}

# --- Écran alternatif ---
printf '\e[?1049h'

build_items
selected=$DEFAULT_CHOICE
fix_selected

while true; do
  draw

  local action=$(read_key)

  case "$action" in
    up)
      local prev=$(( selected - 1 ))
      while (( prev >= 1 )) && [[ "${ITEMS_TYPE[$prev]}" == "group-header" ]]; do
        (( prev-- ))
      done
      (( prev >= 1 )) && selected=$prev
      ;;
    down)
      local next=$(( selected + 1 ))
      while (( next <= ${#ITEMS[@]} )) && [[ "${ITEMS_TYPE[$next]}" == "group-header" ]]; do
        (( next++ ))
      done
      (( next <= ${#ITEMS[@]} )) && selected=$next
      ;;
    enter)
      target="${ITEMS_FULL_PATH[$selected]}"
      if [[ ! -d "$target" ]]; then
        show_message "${RED}✗${RST} Dossier introuvable"
        continue
      fi
      cleanup
      cd "$target"
      export CLAUDE_CODE_FORCE_FULL_LOGO=1
      exec claude
      ;;
    quit)
      cleanup
      exec "${SHELL:-zsh}"
      ;;
    add)
      # Si un récent est sélectionné, l'épingler directement
      if [[ "${ITEMS_TYPE[$selected]}" == "recent" ]]; then
        local pin_path="${ITEMS_FULL_PATH[$selected]}"
        echo "$pin_path" >> "$WORKSPACES_FILE"
        show_message "${GREEN}✓${RST} Épinglé ${DIM}$(basename "$pin_path")${RST}"
        build_items
        selected=1; fix_selected
        continue
      fi
      local new_path=$(prompt_input "Path :")
      new_path="${new_path## }"
      new_path="${new_path%% }"
      new_path="${new_path#\'}" ; new_path="${new_path%\'}"
      new_path="${new_path#\"}" ; new_path="${new_path%\"}"
      new_path="${new_path%/}"
      if [[ -z "$new_path" ]]; then
        continue
      elif [[ ! -d "$new_path" ]]; then
        show_message "${RED}✗${RST} Dossier introuvable"
      else
        local mode=$(prompt_input "Direct ${DIM}d${RST} ou parent ${DIM}p${RST} ? (d/p)")
        if [[ "$mode" == "p" || "$mode" == "P" ]]; then
          local entry=">$new_path"
          if grep -qxF "$entry" "$WORKSPACES_FILE" 2>/dev/null; then
            show_message "${RED}✗${RST} Déjà dans la liste"
          else
            echo "$entry" >> "$WORKSPACES_FILE"
            show_message "${GREEN}✓${RST} Groupe $(basename "$new_path")"
            build_items
            selected=1; fix_selected
          fi
        else
          if grep -qxF "$new_path" "$WORKSPACES_FILE" 2>/dev/null; then
            show_message "${RED}✗${RST} Déjà dans la liste"
          else
            echo "$new_path" >> "$WORKSPACES_FILE"
            show_message "${GREEN}✓${RST} $(basename "$new_path")"
            build_items
            selected=1; fix_selected
          fi
        fi
      fi
      ;;
    del)
      if [[ ${#DIRS[@]} -eq 0 ]]; then
        continue
      fi
      if [[ "${ITEMS_TYPE[$selected]}" == "workspace" ]]; then
        local removed="${ITEMS[$selected]}"
        local dir_to_remove="${ITEMS_FULL_PATH[$selected]}"
        local confirm=$(prompt_input "Supprimer ${BOLD}${removed}${RST} ? (o/N)")
        if [[ "$confirm" == "o" || "$confirm" == "O" ]]; then
          grep -vxF "$dir_to_remove" "$WORKSPACES_FILE" > "$WORKSPACES_FILE.tmp"
          mv "$WORKSPACES_FILE.tmp" "$WORKSPACES_FILE"
          show_message "${GREEN}✓${RST} Supprimé ${DIM}$removed${RST}"
          build_items
          fix_selected
        fi
      elif [[ "${ITEMS_TYPE[$selected]}" == "group-item" ]]; then
        local group_parent="${ITEMS_GROUP[$selected]}"
        local group_name="$(basename "$group_parent")"
        local confirm=$(prompt_input "Supprimer le groupe ${BOLD}${group_name}${RST} ? (o/N)")
        if [[ "$confirm" == "o" || "$confirm" == "O" ]]; then
          grep -vxF ">$group_parent" "$WORKSPACES_FILE" > "$WORKSPACES_FILE.tmp"
          mv "$WORKSPACES_FILE.tmp" "$WORKSPACES_FILE"
          show_message "${GREEN}✓${RST} Supprimé ${DIM}$group_name${RST}"
          build_items
          fix_selected
        fi
      fi
      ;;
    def)
      if [[ "${ITEMS_TYPE[$selected]}" == "workspace" || "${ITEMS_TYPE[$selected]}" == "recent" || "${ITEMS_TYPE[$selected]}" == "group-item" ]]; then
        local def_dir="${ITEMS_FULL_PATH[$selected]}"
        grep -vxF "$def_dir" "$WORKSPACES_FILE" > "$WORKSPACES_FILE.tmp" 2>/dev/null
        { echo "$def_dir"; cat "$WORKSPACES_FILE.tmp"; } > "$WORKSPACES_FILE"
        rm -f "$WORKSPACES_FILE.tmp"
        # Le défaut est toujours ligne 1, déjà déplacé au-dessus
        show_message "${GREEN}✓${RST} Défaut → ${ITEMS[$selected]}"
        build_items
        selected=1; fix_selected
      fi
      ;;
  esac
done
